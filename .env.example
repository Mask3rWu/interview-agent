# ============================================================
# LLM Configuration
# ============================================================
DEFAULT_LLM_PROVIDER=openai_compatible
DEFAULT_LLM_BASE_URL=
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_MODEL=
DEFAULT_LLM_TIMEOUT_SECONDS=12

# Agent-specific model overrides (empty = use DEFAULT_LLM_MODEL)
RESUME_ANALYZER_MODEL=
JOB_ANALYZER_MODEL=
QUESTION_ROUTER_MODEL=
INTERVIEWER_MODEL=
ASSESSMENT_MODEL=

# ============================================================
# Embedding Configuration
# ============================================================
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIMENSIONS=1536

# ============================================================
# App Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
DATA_DIR=data
LOG_DIR=apps/api/logs

# ============================================================
# Supabase (optional — not required for v1)
