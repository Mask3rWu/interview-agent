# ============================================================
# LLM Configuration
# ============================================================
DEFAULT_LLM_PROVIDER=openai_compatible
DEFAULT_LLM_BASE_URL=
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_MODEL=
DEFAULT_LLM_TIMEOUT_SECONDS=12

# Agent-specific model overrides (empty = use DEFAULT_LLM_MODEL)
RESUME_ANALYZER_MODEL=
JOB_ANALYZER_MODEL=
QUESTION_ROUTER_MODEL=
INTERVIEWER_MODEL=
ASSESSMENT_MODEL=
RESUME_ANALYZER_LLM_BACKEND=text
JOB_ANALYZER_LLM_BACKEND=text
QUESTION_ROUTER_LLM_BACKEND=text
INTERVIEWER_LLM_BACKEND=text
ASSESSMENT_LLM_BACKEND=text

# ============================================================
# Multimodal LLM Configuration
# ============================================================
MLLM_BASE_URL=http://localhost:1234/v1
MLLM_API_KEY=lm-studio
MLLM_MODEL=
MLLM_TIMEOUT_SECONDS=60
PDF_VISION_AGENT_MODEL=
PDF_IMAGE_DPI=160
PDF_MAX_PAGES=200
PDF_MAX_IMAGES_PER_PAGE=20
PDF_IMAGE_CONCURRENCY=4

# ============================================================
# Embedding Configuration
# ============================================================
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1/
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024

# ============================================================
# App Configuration
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
DATA_DIR=data
LOG_DIR=apps/api/logs

# ============================================================
# Supabase (optional — not required for v1)
# ============================================================
USE_SUPABASE=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
